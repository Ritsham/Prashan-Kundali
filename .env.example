# Copy this file to .env and paste fresh provider keys locally.
# Do not commit .env.

# groq | openai | gemini | openrouter | cerebras
# Local/off interpretation mode is disabled. Prashna answers must come from an LLM.
PRASHNA_LLM_PROVIDER=groq
PRASHNA_LLM_FALLBACK_PROVIDERS=openrouter,cerebras,groq,openai,gemini
PRASHNA_LLM_TIMEOUT_SECONDS=20

# Groq: use one key or a comma-separated fallback list.
GROQ_INTERPRETATION_MODEL=llama-3.3-70b-versatile
GROQ_API_KEYS=gsk-your-first-key,gsk-your-second-key

# OpenAI: use one key or a comma-separated fallback list.
OPENAI_INTERPRETATION_MODEL=gpt-5.2
OPENAI_API_KEYS=sk-proj-your-first-key,sk-proj-your-second-key

# Gemini: switch PRASHNA_LLM_PROVIDER=gemini to use these.
GEMINI_INTERPRETATION_MODEL=gemini-2.0-flash
GEMINI_API_KEYS=AIza-your-first-key,AIza-your-second-key

# OpenRouter: OpenAI-compatible fallback with rotating keys.
OPENROUTER_INTERPRETATION_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEYS=sk-or-v1-your-first-key,sk-or-v1-your-second-key
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=KundaliStudio

# Cerebras: OpenAI-compatible fallback with rotating keys.
CEREBRAS_INTERPRETATION_MODEL=llama-3.3-70b
CEREBRAS_API_KEYS=csk-your-first-key,csk-your-second-key

# Optional Supabase sync for consultant bookings/chat.
SUPABASE_URL=https://kumkuqiqngilkrbfvouy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
