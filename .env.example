# Shree Lakshmi Astro backend environment example.
# Copy to .env for local development. Do not commit real .env files.

# development | staging | production
APP_ENV=development
LOG_LEVEL=INFO
PUBLIC_SITE_URL=http://localhost:5173

# Public browser origins allowed to call the API. Use exact origins only.
# Production must be https and must not include localhost or *.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# Supabase
# SUPABASE_ANON_KEY is public but must still come from your own project.
# SUPABASE_SERVICE_ROLE_KEY is backend-only. Never expose it to Vite/frontend env vars.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Internal services
# Local/docker defaults are okay in development. Production must point to deployed/private services.
REDIS_URL=redis://localhost:6379/0
ASTROLOGY_ENGINE_URL=http://localhost:8001
LLM_ENGINE_URL=http://localhost:8002
CELERY_WORKER_CONCURRENCY=4

# Development-only switches. Keep false/empty in staging and production.
ALLOW_MOCK_ADMIN_TOKEN=false
ENABLE_LEGACY_UNAUTHENTICATED_WS=false

# Payments
# Set ENABLE_RAZORPAY=true when order creation/verification should be available.
# Production bookings require verified payments by default.
ENABLE_RAZORPAY=false
REQUIRE_VERIFIED_PAYMENT=false
CONSULTATION_PRICE_INR=199.00
FOUNDER_CONSULTANT_PHONE=
FOUNDER_CONSULTANT_WHATSAPP=
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# LLM interpretation
# At least one real provider key is required in production unless REQUIRE_LLM_IN_PRODUCTION=false.
REQUIRE_LLM_IN_PRODUCTION=true
PRASHNA_LLM_PROVIDER=groq
PRASHNA_LLM_FALLBACK_PROVIDERS=openrouter,cerebras,groq,openai,gemini
PRASHNA_LLM_TIMEOUT_SECONDS=20
PRASHNA_LLM_CONTEXT_MODE=compact

GROQ_INTERPRETATION_MODEL=llama-3.3-70b-versatile
GROQ_API_KEYS=gsk-your-first-key,gsk-your-second-key

OPENAI_INTERPRETATION_MODEL=gpt-5.2
OPENAI_API_KEYS=sk-proj-your-first-key,sk-proj-your-second-key

GEMINI_INTERPRETATION_MODEL=gemini-2.0-flash
GEMINI_API_KEYS=AIza-your-first-key,AIza-your-second-key

OPENROUTER_INTERPRETATION_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEYS=sk-or-v1-your-first-key,sk-or-v1-your-second-key
OPENROUTER_SITE_URL=https://your-frontend.example.com
OPENROUTER_APP_NAME=ShreeLakshmiAstro

CEREBRAS_INTERPRETATION_MODEL=llama-3.3-70b
CEREBRAS_API_KEYS=csk-your-first-key,csk-your-second-key
