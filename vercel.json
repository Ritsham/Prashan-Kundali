{
  "buildCommand": "node build.js",
  "outputDirectory": "public",
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{.git/**,.agents/**,.codex/**,.vercel/**,.venv/**,__pycache__/**,.pycache/**,.pycache-build/**,node_modules/**,frontend/node_modules/**,frontend/dist/**,frontend/src/**,frontend/public/**,frontend/*.json,frontend/*.ts,frontend/*.html,docs/**,scripts/**,services/**,data/**,ephemeris/**,validation/generated_outputs.csv,*.db,*.sqlite3,Dockerfile,docker-compose*.yml,README*.md}"
    }
  },
  "headers": [
    {
      "source": "/frontend_old/(.*)\\.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/frontend_old/(.*)\\.css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/frontend_old/(.*)\\.webp",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/frontend_old/(.*)\\.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/frontend_old/(.*)\\.jpg",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/frontend_old/(.*)\\.svg",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/frontend_old/(.*)\\.woff2",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/frontend_old/(.*)\\.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)\\.webp",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)\\.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
